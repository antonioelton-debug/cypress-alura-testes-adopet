# Dependências
node_modules/
.pnp/
.pnp.js

# Cypress: Vídeos e Screenshots de testes que falharam
# (Geralmente você não quer versionar isso, pois ocupam muito espaço)
cypress/screenshots/
cypress/videos/

# Cypress: Resultados de relatórios (se usar mochawesome ou similares)
cypress/reports/

# Arquivos de ambiente e segredos (Senhas, chaves de API, etc)
cypress.env.json
.env
.env.local
.env.*.local

# Logs de erro do NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Arquivos do Sistema Operacional
.DS_Store
Thumbs.db

# Pastas de IDEs
.vscode/
.idea/